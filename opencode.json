{
  "$schema": "https://opencode.ai/config.json",
  "model": "local/mlx-community/Qwen3.6-35B-A3B-4bit",
  "small_model": "local/mlx-community/Qwen3.6-35B-A3B-4bit",
  "default_agent": "workstation",
  "autoupdate": false,
  "share": "disabled",
  "enabled_providers": ["local"],
  "instructions": [".opencode/rules/local-workstation.md"],
  "provider": {
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "BOS Local Runtime",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "local-only"
      },
      "models": {
        "mlx-community/Qwen3.6-35B-A3B-4bit": {
          "name": "Qwen3.6 35B A3B 4-bit (default)",
          "limit": {
            "context": 65536,
            "output": 32768
          }
        },
        "mlx-community/Qwen3-Coder-Next-4bit": {
          "name": "Qwen3 Coder Next 4-bit (challenger)",
          "limit": {
            "context": 65536,
            "output": 32768
          }
        },
        "qwen3.6:35b": {
          "name": "Qwen3.6 35B A3B (DGX Spark default)",
          "limit": {
            "context": 65536,
            "output": 32768
          }
        },
        "qwen3-coder-next": {
          "name": "Qwen3 Coder Next (DGX Spark challenger)",
          "limit": {
            "context": 65536,
            "output": 32768
          }
        },
        "Qwen/Qwen3-Coder-30B-A3B-Instruct": {
          "name": "Qwen3 Coder 30B A3B (Linux default)",
          "limit": {
            "context": 65536,
            "output": 32768
          }
        },
        "Qwen/Qwen3-Coder-Next": {
          "name": "Qwen3 Coder Next (Linux challenger)",
          "limit": {
            "context": 65536,
            "output": 32768
          }
        }
      }
    }
  },
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "todowrite": "allow",
    "webfetch": "deny",
    "websearch": "deny",
    "external_directory": "ask",
    "doom_loop": "ask",
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "sudo *": "ask",
      "git reset *": "ask",
      "git clean *": "ask",
      "git checkout -- *": "ask",
      "git restore *": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "git tag *": "ask",
      "git rebase *": "ask",
      "npm install *": "ask",
      "npm add *": "ask",
      "pnpm install *": "ask",
      "pnpm add *": "ask",
      "yarn add *": "ask",
      "bun add *": "ask",
      "pip install *": "ask",
      "uv add *": "ask",
      "uv pip install *": "ask",
      "brew install *": "ask",
      "curl *": "deny",
      "wget *": "deny"
    }
  },
  "agent": {
    "workstation": {
      "description": "Local autonomous coding agent that plans before implementation",
      "mode": "primary",
      "prompt": "{file:./.opencode/prompts/workstation.md}",
      "permission": {
        "task": "allow"
      }
    }
  }
}
