# Copy this file to .env and fill in local machine secrets.
# Keep .env private; it is ignored by git.

# Optional: Hugging Face token for faster and more reliable model downloads.
# Create one at https://huggingface.co/settings/tokens with read access.
HF_TOKEN=

# Recommended on Linux/DGX Spark: use standard HTTP downloads instead of Xet.
HF_HUB_DISABLE_XET=1
